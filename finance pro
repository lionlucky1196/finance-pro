const Charts = {
  instances: {},
  destroy(id) {
    if (this.instances[id]) { this.instances[id].destroy(); delete this.instances[id]; }
  },
  colors() {
    const s = getComputedStyle(document.documentElement);
    return {
      primary: s.getPropertyValue('--primary').trim() || '#6366f1',
      income:  s.getPropertyValue('--income').trim()  || '#10b981',
      expense: s.getPropertyValue('--expense').trim() || '#ef4444',
