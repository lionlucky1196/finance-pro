<script>
/* =========================================================
   database.js — IndexedDB wrapper for FinancePro
   ========================================================= */
const DB_NAME = 'financepro_db';
const DB_VERSION = 1;
const STORES = {
  transactions: 'transactions', persons: 'persons', categories: 'categories',
  settings: 'settings', notes: 'notes', reminders: 'reminders',
  recurring: 'recurring', templates: 'templates'
};

class Database {
  constructor() { this.db = null; }
  open() {
    return new Promise((resolve, reject) => {
      const req = indexedDB.open(DB_NAME, DB_VERSION);
      req.onupgradeneeded = (e) => {
        const db = e.target.result;
        if (!db.objectStoreNames.contains(STORES.transactions)) {
          const txs = db.createObjectStore(STORES.transactions, { keyPath: 'id' });
          txs.createIndex('date', 'date', { unique: false });
          txs.createIndex('type', 'type', { unique: false });
          txs.createIndex('category', 'category', { unique: false });
          txs.createIndex('personId', 'personId', { unique: false });
          txs.createIndex('paymentMethod', 'paymentMethod', { unique: false });
        }
        [STORES.persons, STORES.categories, STORES.notes,
         STORES.reminders, STORES.recurring, STORES.templates].forEach(name => {
          if (!db.objectStoreNames.contains(name)) db.createObjectStore(name, { keyPath: 'id' });
        });
        if (!db.objectStoreNames.contains(STORES.settings))
          db.createObjectStore(STORES.settings, { keyPath: 'key' });
      };
      req.onsuccess = (e) => { this.db = e.target.result; resolve(this.db); };
      req.onerror   = (e) => reject(e.target.error);
    });
  }
  _tx(storeName, mode = 'readonly') {
    return this.db.transaction(storeName, mode).objectStore(storeName);
  }
  put(storeName, item) {
    return new Promise((resolve, reject) => {
      const req = this._tx(storeName, 'readwrite').put(item);
      req.onsuccess = () => resolve(item);
      req.onerror   = (e) => reject(e.target.error);
    });
  }
  get(storeName, key) {
    return new Promise((resolve, reject) => {
      const req = this._tx(storeName).get(key);
      req.onsuccess = () => resolve(req.result);
      req.onerror   = (e) => reject(e.target.error);
    });
  }
  getAll(storeName) {
    return new Promise((resolve, reject) => {
      const req = this._tx(storeName).getAll();
      req.onsuccess = () => resolve(req.result || []);
      req.onerror   = (e) => reject(e.target.error);
    });
  }
  delete(storeName, key) {
    return new Promise((resolve, reject) => {
      const req = this._tx(storeName, 'readwrite').delete(key);
      req.onsuccess = () => resolve();
      req.onerror   = (e) => reject(e.target.error);
    });
  }
  clear(storeName) {
    return new Promise((resolve, reject) => {
      const req = this._tx(storeName, 'readwrite').clear();
      req.onsuccess = () => resolve();
      req.onerror   = (e) => reject(e.target.error);
    });
  }
  async backup() {
    const data = {};
    for (const key of Object.values(STORES)) data[key] = await this.getAll(key);
    data.__exportedAt = new Date().toISOString();
    data.__version = DB_VERSION;
    return data;
  }
  async restore(data) {
    for (const key of Object.values(STORES)) {
      if (Array.isArray(data[key])) {
        await this.clear(key);
        for (const item of data[key]) await this.put(key, item);
      }
    }
  }
  async reset() {
    for (const key of Object.values(STORES)) await this.clear(key);
  }
}
const db = new Database();

/* =========================================================
   utils.js — Helpers
   ========================================================= */
function uid(prefix = '') {
  return prefix + Date.now().toString(36) + Math.random().toString(36).slice(2, 8);
}
function money(n) {
  const cur = (window.Settings && Settings.get('currency')) || '₹';
  const v = Number(n || 0);
  const formatted = Math.abs(v).toLocaleString('en-IN', { minimumFractionDigits: 0, maximumFractionDigits: 2 });
  const sign = v < 0 ? '-' : '';
  return `${sign}${cur}${formatted}`;
}
function fmtDate(iso) {
  if (!iso) return '';
  const d = new Date(iso);
  if (isNaN(d)) return iso;
  const fmt = (window.Settings && Settings.get('dateFormat')) || 'DD/MM/YYYY';
  const dd = String(d.getDate()).padStart(2,'0');
  const mm = String(d.getMonth()+1).padStart(2,'0');
  const yy = d.getFullYear();
  if (fmt === 'MM/DD/YYYY') return `${mm}/${dd}/${yy}`;
  if (fmt === 'YYYY-MM-DD') return `${yy}-${mm}-${dd}`;
  return `${dd}/${mm}/${yy}`;
}
function fmtDateTime(iso) {
  if (!iso) return '';
  const d = new Date(iso);
  return `${fmtDate(iso)} ${String(d.getHours()).padStart(2,'0')}:${String(d.getMinutes()).padStart(2,'0')}`;
}
function todayISO() {
  const d = new Date();
  return `${d.getFullYear()}-${String(d.getMonth()+1).padStart(2,'0')}-${String(d.getDate()).padStart(2,'0')}`;
}
function nowISO() { return new Date().toISOString(); }
function greeting() {
  const h = new Date().getHours();
  if (h < 5) return 'Good night';
  if (h < 12) return 'Good morning';
  if (h < 17) return 'Good afternoon';
  if (h < 21) return 'Good evening';
  return 'Good night';
}
function txTypeIcon(type) {
  const map = {
    'Income': 'arrow_downward', 'Expense': 'arrow_upward',
    'Transfer': 'swap_horiz', 'Loan Given': 'payments',
    'Loan Taken': 'request_quote', 'Investment': 'trending_up',
    'Salary': 'work', 'Business': 'business', 'Other': 'more_horiz'
  };
  return map[type] || 'receipt';
}
function txTypeClass(type) {
  if (type === 'Income' || type === 'Salary' || type === 'Loan Taken') return 'income';
  if (type === 'Expense') return 'expense';
  if (type === 'Transfer' || type === 'Investment' || type === 'Business') return 'transfer';
  if (type === 'Loan Given') return 'loan';
  return 'transfer';
}
function txSign(type) {
  if (['Income','Salary','Loan Taken','Investment Return'].includes(type)) return +1;
  if (['Expense','Loan Given','Investment'].includes(type)) return -1;
  return 0;
}
function toast(msg, kind = 'info', action = null) {
  const root = document.getElementById('toastRoot');
  const el = document.createElement('div');
  el.className = `toast ${kind}`;
  el.innerHTML = `<span>${msg}</span>`;
  if (action) {
    const btn = document.createElement('button');
    btn.textContent = action.label;
    btn.onclick = () => { action.onClick(); el.remove(); };
    el.appendChild(btn);
  }
  root.appendChild(el);
  setTimeout(() => { el.style.opacity = '0'; setTimeout(() => el.remove(), 300); }, 3500);
}
function openModal(title, bodyHtml, footerHtml = '') {
  closeAllModals();
  const root = document.getElementById('modalRoot');
  const m = document.createElement('div');
  m.className = 'modal';
  m.innerHTML = `
    <div class="modal-content">
      <div class="modal-head">
        <h3>${title}</h3>
        <button class="icon-btn" onclick="closeAllModals()"><span class="material-icons-round">close</span></button>
      </div>
      <div class="modal-body">${bodyHtml}</div>
      ${footerHtml ? `<div class="modal-foot">${footerHtml}</div>` : ''}
    </div>`;
  m.addEventListener('click', (e) => { if (e.target === m) closeAllModals(); });
  root.appendChild(m);
  return m;
}
function closeAllModals() {
  document.getElementById('modalRoot').innerHTML = '';
}
function confirmDialog(msg, onYes) {
  openModal('Confirm',
    `<p style="padding:10px 0">${msg}</p>`,
    `<button class="btn btn-ghost" onclick="closeAllModals()">Cancel</button>
     <button class="btn btn-danger" id="confirmYes">Yes</button>`);
  document.getElementById('confirmYes').onclick = () => { closeAllModals(); onYes(); };
}
function debounce(fn, ms = 300) {
  let t; return (...a) => { clearTimeout(t); t = setTimeout(() => fn(...a), ms); };
}
async function shareText(title, text) {
  if (navigator.share) {
    try { await navigator.share({ title, text }); } catch {}
  } else {
    navigator.clipboard?.writeText(text);
    toast('Copied to clipboard', 'success');
  }
}
function printHtml(html, title = 'FinancePro Report') {
  const w = window.open('', '_blank');
  w.document.write(`<!DOCTYPE html><html><head><title>${title}</title>
    <style>body{font-family:sans-serif;padding:20px}table{width:100%;border-collapse:collapse}
    th,td{border:1px solid #ccc;padding:8px;text-align:left}th{background:#f0f0f0}</style>
    </head><body><h2>${title}</h2>${html}<p style="margin-top:30px;color:#888;font-size:12px">
    Generated by FinancePro — ${new Date().toLocaleString()}</p></body></html>`);
  w.document.close();
  setTimeout(() => w.print(), 400);
}
function downloadFile(filename, content, mime = 'text/plain') {
  const blob = content instanceof Blob ? content : new Blob([content], { type: mime });
  const url = URL.createObjectURL(blob);
  const a = document.createElement('a');
  a.href = url; a.download = filename; a.click();
  setTimeout(() => URL.revokeObjectURL(url), 1000);
}
function escapeHtml(s) {
  if (s === null || s === undefined) return '';
  return String(s).replace(/[&<>"']/g, c => ({
    '&':'&amp;','<':'&lt;','>':'&gt;','"':'&quot;',"'":'&#39;'
  }[c]));
}

/* =========================================================
   settings.js — User preferences
   ========================================================= */
const Settings = {
  defaults: {
    currency: '₹', dateFormat: 'DD/MM/YYYY', theme: 'light',
    themeColor: 'indigo', pinHash: '', autoLock: 5
  },
  cache: {},
  async load() {
    const all = await db.getAll(STORES.settings);
    this.cache = {};
    all.forEach(row => this.cache[row.key] = row.value);
  },
  get(key) {
    if (key in this.cache) return this.cache[key];
    return this.defaults[key];
  },
  async set(key, value) {
    this.cache[key] = value;
    await db.put(STORES.settings, { key, value });
  },
  applyTheme() {
    document.documentElement.setAttribute('data-theme', this.get('theme'));
    document.documentElement.setAttribute('data-color', this.get('themeColor'));
    const btn = document.getElementById('themeToggle');
    if (btn) btn.querySelector('span').textContent =
      this.get('theme') === 'dark' ? 'light_mode' : 'dark_mode';
  },
  hashPin(pin) {
    let h = 0;
    const s = 'fp_salt_' + pin;
    for (let i = 0; i < s.length; i++) {
      h = ((h << 5) - h) + s.charCodeAt(i);
      h |= 0;
    }
    return String(h);
  },
  async setPin(pin) {
    if (!pin) { await this.set('pinHash', ''); return; }
    await this.set('pinHash', this.hashPin(pin));
  },
  verifyPin(pin) {
    const stored = this.get('pinHash');
    if (!stored) return true;
    return stored === this.hashPin(pin);
  },
  hasLock() { return !!this.get('pinHash'); }
};

/* =========================================================
   ledger.js — Person / Ledger management
   ========================================================= */
const Ledger = {
  async savePerson(person) {
    if (!person.id) person.id = uid('p_');
    if (!person.createdAt) person.createdAt = nowISO();
    person.updatedAt = nowISO();
    await db.put(STORES.persons, person);
    return person;
  },
  async deletePerson(id) { await db.delete(STORES.persons, id); },
  async getAll() { return await db.getAll(STORES.persons); },
  async get(id) { return await db.get(STORES.persons, id); },
  async getStats(personId) {
    const txs = await db.getAll(STORES.transactions);
    const rel = txs.filter(t => t.personId === personId);
    let given = 0, received = 0, lastDate = '';
    rel.forEach(t => {
      const amt = Number(t.amount) || 0;
      if (['Expense','Loan Given'].includes(t.type)) given += amt;
      if (['Income','Loan Taken','Salary'].includes(t.type)) received += amt;
      if (!lastDate || t.date > lastDate) lastDate = t.date;
    });
    return { given, received, balance: received - given, txCount: rel.length, lastDate };
  },
  async render(search = '') {
    const list = document.getElementById('personList');
    const empty = document.getElementById('personEmpty');
    const all = await this.getAll();
    const q = search.trim().toLowerCase();
    const filtered = q
      ? all.filter(p => (p.name||'').toLowerCase().includes(q) || (p.phone||'').includes(q))
      : all;
    filtered.sort((a,b) => (b.favorite?1:0) - (a.favorite?1:0) || (a.name||'').localeCompare(b.name||''));
    if (filtered.length === 0) { list.innerHTML = ''; empty.classList.remove('hidden'); return; }
    empty.classList.add('hidden');
