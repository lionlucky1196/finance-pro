                ${escapeHtml(p.name)}
              </div>
              <div class="person-phone">${escapeHtml(p.phone||'No phone')}</div>
            </div>
            <button class="icon-btn" data-act="fav" data-id="${p.id}" title="Favorite">
              <span class="material-icons-round">${p.favorite?'star':'star_border'}</span>
            </button>
            <button class="icon-btn" data-act="edit" data-id="${p.id}">
              <span class="material-icons-round">edit</span>
            </button>
          </div>
          <div class="person-stats">
