      info:    s.getPropertyValue('--info').trim()    || '#3b82f6',
      text:    s.getPropertyValue('--text-muted').trim() || '#64748b',
      grid:    s.getPropertyValue('--border').trim() || '#e2e8f0'
    };
  },
  commonOpts() {
    const c = this.colors();
    return {
      responsive: true, maintainAspectRatio: false,
      plugins: {
        legend: { labels: { color: c.text, font: { family: 'Inter' } } },
        tooltip: { backgroundColor: 'rgba(0,0,0,.8)', padding: 10, cornerRadius: 8 }
      },
