  async exportAll(format) {
    const txs = await db.getAll(STORES.transactions);
    const persons = await db.getAll(STORES.persons);
    if (!txs.length) { toast('No data to export', 'error'); return; }
    if (format === 'csv') {
      const head = 'ID,Date,Time,Type,Category,Amount,Person,Phone,Payment,Reference,Description,Notes,Tags\n';
      const rows = txs.map(t =>
        [t.id,t.date,t.time||'',t.type,t.category||'',t.amount,t.personName||'',t.phone||'',
         t.paymentMethod||'',t.reference||'',t.description||'',t.notes||'',(t.tags||[]).join('|')]
         .map(v => `"${String(v).replace(/"/g,'""')}"`).join(',')
      ).join('\n');
      downloadFile(`financepro_${todayISO()}.csv`, head + rows, 'text/csv');
    }
    else if (format === 'xlsx') {
      const ws = XLSX.utils.json_to_sheet(txs.map(t => ({
        Date: t.date, Time: t.time, Type: t.type, Category: t.category,
        Amount: t.amount, Person: t.personName, Phone: t.phone,
        Payment: t.paymentMethod, Reference: t.reference,
        Description: t.description, Notes: t.notes, Tags: (t.tags||[]).join(', ')
      })));
      const wb = XLSX.utils.book_new();
      XLSX.utils.book_append_sheet(wb, ws, 'Transactions');
      if (persons.length) {
        const ps = XLSX.utils.json_to_sheet(persons);
        XLSX.utils.book_append_sheet(wb, ps, 'Persons');
      }
      XLSX.writeFile(wb, `financepro_${todayISO()}.xlsx`);
    }
    else if (format === 'pdf') {
      const { jsPDF } = window.jspdf;
      const doc = new jsPDF();
      doc.setFontSize(16); doc.text('FinancePro Report', 14, 18);
      doc.setFontSize(10); doc.text(`Generated: ${new Date().toLocaleString()}`, 14, 26);
      doc.autoTable({
        startY: 32,
        head: [['Date','Type','Category','Person','Amount','Payment']],
        body: txs.map(t => [t.date, t.type, t.category||'', t.personName||'', Number(t.amount).toFixed(2), t.paymentMethod||'']),
        styles: { fontSize: 8 },
        headStyles: { fillColor: [99,102,241] }
      });
      doc.save(`financepro_${todayISO()}.pdf`);
    }
    toast('Exported', 'success');
  },

