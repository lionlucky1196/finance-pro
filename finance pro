  async refreshDashboard() {
    const txs = await db.getAll(STORES.transactions);
    const today = todayISO();
    const now = new Date();
    const monthKey = `${now.getFullYear()}-${String(now.getMonth()+1).padStart(2,'0')}`;
    let totalInc = 0, totalExp = 0, todayNet = 0, todayCount = 0;
    let monthInc = 0, monthExp = 0, outstanding = 0;
    txs.forEach(t => {
      const a = Number(t.amount)||0;
      const sign = txSign(t.type);
      if (sign > 0) totalInc += a;
      if (sign < 0) totalExp += a;
      if (t.date === today) { todayNet += sign*a; todayCount++; }
      if (t.date && t.date.startsWith(monthKey)) {
        if (sign > 0) monthInc += a;
        if (sign < 0) monthExp += a;
      }
      if (t.type === 'Loan Given') outstanding += a;
      if (t.type === 'Loan Taken') outstanding -= a;
    });
    const balance = totalInc - totalExp;
    const profit = monthInc - monthExp;
    document.getElementById('statBalance').textContent = money(balance);
    document.getElementById('statIncome').textContent  = money(totalInc);
    document.getElementById('statExpense').textContent = money(totalExp);
    document.getElementById('statToday').textContent   = money(todayNet);
    document.getElementById('statTodaySub').textContent = `${todayCount} transactions`;
    document.getElementById('statMonthIn').textContent = money(monthInc);
    document.getElementById('statMonthOut').textContent= money(monthExp);
    document.getElementById('statProfit').textContent  = money(profit);
    document.getElementById('statProfit').style.color  = profit >= 0 ? 'var(--income)' : 'var(--expense)';
    document.getElementById('statLoan').textContent    = money(outstanding);

    const recent = [...txs].sort((a,b) => (b.date+(b.time||'')).localeCompare(a.date+(a.time||''))).slice(0,5);
    const list = document.getElementById('recentTxList');
    list.innerHTML = recent.length ? recent.map(t => this.txItemHtml(t)).join('')
      : '<p class="muted" style="text-align:center;padding:20px">No transactions yet</p>';
    this.attachTxItemListeners(list);

    await Charts.renderOverview('chartOverview');
    await Charts.renderTopExpenses('chartTopExp');
    await Charts.renderCashflow('chartCashflow');
  },

  async renderTransactions(searchQ = '') {
    const q = searchQ || document.getElementById('globalSearch')?.value || '';
    let txs = await db.getAll(STORES.transactions);
    const fFrom = document.getElementById('fFrom')?.value;
    const fTo = document.getElementById('fTo')?.value;
    const fType = document.getElementById('fType')?.value;
    const fCat = document.getElementById('fCategory')?.value;
    const fPer = document.getElementById('fPerson')?.value;
    const fPay = document.getElementById('fPayment')?.value;
    const fMin = parseFloat(document.getElementById('fMin')?.value);
    const fMax = parseFloat(document.getElementById('fMax')?.value);
    if (fFrom) txs = txs.filter(t => t.date >= fFrom);
    if (fTo)   txs = txs.filter(t => t.date <= fTo);
    if (fType) txs = txs.filter(t => t.type === fType);
    if (fCat)  txs = txs.filter(t => t.category === fCat);
    if (fPer)  txs = txs.filter(t => t.personId === fPer);
    if (fPay)  txs = txs.filter(t => t.paymentMethod === fPay);
    if (!isNaN(fMin)) txs = txs.filter(t => Number(t.amount) >= fMin);
    if (!isNaN(fMax)) txs = txs.filter(t => Number(t.amount) <= fMax);
    if (q) {
      const ql = q.toLowerCase();
      const persons = await db.getAll(STORES.persons);
      const pMap = {}; persons.forEach(p => pMap[p.id] = p.name);
      txs = txs.filter(t => {
        return (t.category||'').toLowerCase().includes(ql) ||
               (t.description||'').toLowerCase().includes(ql) ||
               (t.personName||pMap[t.personId]||'').toLowerCase().includes(ql) ||
               (t.phone||'').includes(ql) ||
               (t.reference||'').toLowerCase().includes(ql) ||
               String(t.amount).includes(ql) ||
               (t.date||'').includes(ql);
      });
    }
    this.populateFilterDropdowns();
    txs.sort((a,b) => (b.date+(b.time||'')).localeCompare(a.date+(a.time||'')));
    const list = document.getElementById('txList');
    const empty = document.getElementById('txEmpty');
    if (txs.length === 0) { list.innerHTML = ''; empty.classList.remove('hidden'); return; }
    empty.classList.add('hidden');
    list.innerHTML = txs.map(t => this.txItemHtml(t)).join('');
    this.attachTxItemListeners(list);
  },

  async populateFilterDropdowns() {
    const catSel = document.getElementById('fCategory');
    const perSel = document.getElementById('fPerson');
    const cats = await db.getAll(STORES.categories);
    const persons = await db.getAll(STORES.persons);
    const curCat = catSel.value, curPer = perSel.value;
    catSel.innerHTML = '<option value="">All</option>' +
      cats.map(c => `<option value="${escapeHtml(c.name)}">${escapeHtml(c.name)}</option>`).join('');
    perSel.innerHTML = '<option value="">All</option>' +
      persons.map(p => `<option value="${p.id}">${escapeHtml(p.name)}</option>`).join('');
    catSel.value = curCat; perSel.value = curPer;
  },

  txItemHtml(t) {
    const cls = txTypeClass(t.type);
    const sign = txSign(t.type);
    const signChar = sign > 0 ? '+' : sign < 0 ? '-' : '';
    const subtitle = [t.category || t.type, t.personName || '', t.paymentMethod || ''].filter(Boolean).join(' • ');
    return `
      <div class="tx-item" data-id="${t.id}">
        <div class="tx-icon ${cls}"><span class="material-icons-round">${txTypeIcon(t.type)}</span></div>
        <div class="tx-body">
          <div class="tx-title">${escapeHtml(t.description || t.category || t.type)}</div>
          <div class="tx-sub">
            <span>${fmtDateTime(t.date+'T'+(t.time||'00:00'))}</span>
            <span>• ${escapeHtml(subtitle)}</span>
          </div>
        </div>
        <div class="tx-amount ${cls}">${signChar}${money(t.amount)}</div>
        <button class="tx-menu-btn" data-menu="${t.id}"><span class="material-icons-round">more_vert</span></button>
      </div>`;
  },

  attachTxItemListeners(container) {
    container.querySelectorAll('.tx-item').forEach(item => {
      item.addEventListener('click', (e) => {
        if (e.target.closest('[data-menu]')) return;
        this.openTxDetail(item.dataset.id);
