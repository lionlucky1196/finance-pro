/* =========================================================
   reports.js — Report generators
   ========================================================= */
const Reports = {
  filterByRange(txs, from, to) {
    return txs.filter(t => t.date >= from && t.date <= to);
  },
  summarize(txs) {
    let inc = 0, exp = 0, count = txs.length;
    txs.forEach(t => {
      const a = Number(t.amount)||0;
      if (txSign(t.type) > 0) inc += a;
      if (txSign(t.type) < 0) exp += a;
    });
    return { income: inc, expense: exp, profit: inc - exp, count };
  },
  groupBy(txs, keyFn) {
    const g = {};
    txs.forEach(t => { const k = keyFn(t); if (!g[k]) g[k] = []; g[k].push(t); });
    return g;
  },
  async render(type) {
    const txs = await db.getAll(STORES.transactions);
    const container = document.getElementById('reportContent');
    const today = new Date();
    let title = '', rows = [];

    if (type === 'daily') {
      const groups = [];
      for (let i = 0; i < 14; i++) {
        const d = new Date(today); d.setDate(d.getDate()-i);
        const key = d.toISOString().slice(0,10);
        groups.push({ label: fmtDate(key), txs: txs.filter(t => t.date === key) });
      }
      rows = groups.map(g => { const s = this.summarize(g.txs); return { label: g.label, count: s.count, income: s.income, expense: s.expense, profit: s.profit }; });
      title = 'Daily Report (Last 14 days)';
    }
    else if (type === 'weekly') {
      const groups = [];
      for (let w = 0; w < 8; w++) {
        const end = new Date(today); end.setDate(end.getDate() - w*7);
        const start = new Date(end); start.setDate(start.getDate() - 6);
        const sISO = start.toISOString().slice(0,10);
        const eISO = end.toISOString().slice(0,10);
        groups.push({ label: `${fmtDate(sISO)} - ${fmtDate(eISO)}`, txs: this.filterByRange(txs, sISO, eISO) });
      }
      rows = groups.map(g => { const s = this.summarize(g.txs); return { label: g.label, count: s.count, income: s.income, expense: s.expense, profit: s.profit }; });
      title = 'Weekly Report (Last 8 weeks)';
    }
    else if (type === 'monthly') {
      const groups = [];
      for (let i = 0; i < 12; i++) {
        const d = new Date(today.getFullYear(), today.getMonth() - i, 1);
        const last = new Date(d.getFullYear(), d.getMonth()+1, 0);
        const sISO = d.toISOString().slice(0,10);
        const eISO = last.toISOString().slice(0,10);
        groups.push({ label: d.toLocaleString('default', { month: 'long', year: 'numeric' }), txs: this.filterByRange(txs, sISO, eISO) });
      }
      rows = groups.map(g => { const s = this.summarize(g.txs); return { label: g.label, count: s.count, income: s.income, expense: s.expense, profit: s.profit }; });
      title = 'Monthly Report (Last 12 months)';
    }
    else if (type === 'yearly') {
      const years = {};
      txs.forEach(t => { const y = t.date.slice(0,4); if (!years[y]) years[y] = []; years[y].push(t); });
      rows = Object.keys(years).sort().reverse().map(y => { const s = this.summarize(years[y]); return { label: y, count: s.count, income: s.income, expense: s.expense, profit: s.profit }; });
      title = 'Yearly Report';
    }
    else if (type === 'category') {
      const groups = this.groupBy(txs, t => t.category || 'Uncategorized');
      rows = Object.entries(groups).map(([cat, arr]) => { const s = this.summarize(arr); return { label: cat, count: s.count, income: s.income, expense: s.expense, profit: s.profit }; }).sort((a,b) => (b.income + b.expense) - (a.income + a.expense));
      title = 'Category Wise Report';
    }
    else if (type === 'person') {
      const persons = await db.getAll(STORES.persons);
      const pMap = {}; persons.forEach(p => pMap[p.id] = p.name);
      const groups = this.groupBy(txs, t => t.personId ? (pMap[t.personId] || 'Unknown') : 'No person');
      rows = Object.entries(groups).map(([name, arr]) => { const s = this.summarize(arr); return { label: name, count: s.count, income: s.income, expense: s.expense, profit: s.profit }; }).sort((a,b) => (b.income + b.expense) - (a.income + a.expense));
      title = 'Person Wise Report';
    }
    else if (type === 'payment') {
      const groups = this.groupBy(txs, t => t.paymentMethod || 'Not specified');
      rows = Object.entries(groups).map(([pm, arr]) => { const s = this.summarize(arr); return { label: pm, count: s.count, income: s.income, expense: s.expense, profit: s.profit }; }).sort((a,b) => (b.income + b.expense) - (a.income + a.expense));
      title = 'Payment Method Report';
    }

    const totalInc = rows.reduce((a,r)=>a+r.income,0);
    const totalExp = rows.reduce((a,r)=>a+r.expense,0);
    const totalCnt = rows.reduce((a,r)=>a+r.count,0);

    container.innerHTML = `
      <h3 style="margin-bottom:10px">${title}</h3>
      <div class="report-summary">
        <div class="summary-box"><div class="label">Transactions</div><div class="value">${totalCnt}</div></div>
        <div class="summary-box"><div class="label">Income</div><div class="value" style="color:var(--income)">${money(totalInc)}</div></div>
        <div class="summary-box"><div class="label">Expense</div><div class="value" style="color:var(--expense)">${money(totalExp)}</div></div>
      </div>
      <div style="overflow-x:auto">
        <table class="report-table">
          <thead><tr><th>Period / Group</th><th>Txn</th><th>Income</th><th>Expense</th><th>Net</th></tr></thead>
          <tbody>
            ${rows.map(r => `
              <tr>
                <td><strong>${escapeHtml(r.label)}</strong></td>
                <td>${r.count}</td>
                <td style="color:var(--income)">${money(r.income)}</td>
                <td style="color:var(--expense)">${money(r.expense)}</td>
                <td style="color:${r.profit>=0?'var(--income)':'var(--expense)'}; font-weight:600">${money(r.profit)}</td>
              </tr>`).join('')}
          </tbody>
        </table>
      </div>
    `;
    this._lastRows = rows;
    this._lastTitle = title;
  },
  exportCurrent(format) {
    const rows = this._lastRows || [];
    const title = this._lastTitle || 'Report';
    if (!rows.length) { toast('No data to export', 'error'); return; }
    if (format === 'csv') {
      const head = 'Period,Count,Income,Expense,Net\n';
      const body = rows.map(r => `"${r.label}",${r.count},${r.income},${r.expense},${r.profit}`).join('\n');
      downloadFile(`${title}.csv`, head + body, 'text/csv');
    }
    else if (format === 'json') {
      downloadFile(`${title}.json`, JSON.stringify({title, rows}, null, 2), 'application/json');
    }
    else if (format === 'xlsx') {
      const ws = XLSX.utils.json_to_sheet(rows.map(r => ({ Period: r.label, Transactions: r.count, Income: r.income, Expense: r.expense, Net: r.profit })));
      const wb = XLSX.utils.book_new();
      XLSX.utils.book_append_sheet(wb, ws, 'Report');
      XLSX.writeFile(wb, `${title}.xlsx`);
    }
    else if (format === 'pdf') {
      const { jsPDF } = window.jspdf;
      const doc = new jsPDF();
      doc.setFontSize(16); doc.text(title, 14, 18);
      doc.setFontSize(10); doc.text(`Generated: ${new Date().toLocaleString()}`, 14, 26);
      doc.autoTable({
        startY: 32,
        head: [['Period','Txn','Income','Expense','Net']],
        body: rows.map(r => [r.label, r.count, r.income.toFixed(2), r.expense.toFixed(2), r.profit.toFixed(2)]),
        styles: { fontSize: 9 },
        headStyles: { fillColor: [99,102,241] }
      });
      doc.save(`${title}.pdf`);
    }
    else if (format === 'print') {
      const table = `
        <table><thead><tr><th>Period</th><th>Txn</th><th>Income</th><th>Expense</th><th>Net</th></tr></thead>
        <tbody>${rows.map(r => `<tr><td>${escapeHtml(r.label)}</td><td>${r.count}</td><td>${r.income}</td><td>${r.expense}</td><td>${r.profit}</td></tr>`).join('')}</tbody></table>`;
      printHtml(table, title);
    }
    toast('Exported', 'success');
  }
};

