  },
  updatePinDisplay() {
    const spans = document.querySelectorAll('.pin-display span');
    spans.forEach((s,i) => s.classList.toggle('filled', i < this._pinBuf.length));
  },
  async handlePinKey(k) {
    if (k === 'clear') { this._pinBuf = ''; }
    else if (k === 'back') { this._pinBuf = this._pinBuf.slice(0,-1); }
    else if (this._pinBuf.length < 4) { this._pinBuf += k; }
    this.updatePinDisplay();
    if (this._pinBuf.length === 4) {
      if (this._setupMode) {
        await Settings.setPin(this._pinBuf);
        toast('PIN set successfully', 'success');
        this._setupMode = false;
        document.getElementById('lockMessage').textContent = 'Enter your PIN to unlock';
        this._pinBuf = '';
        this.updatePinDisplay();
        return;
      }
      if (Settings.verifyPin(this._pinBuf)) {
        document.getElementById('lockScreen').classList.add('hidden');
        document.getElementById('app').classList.remove('hidden');
        this._pinBuf = '';
      } else {
        toast('Wrong PIN', 'error');
        this._pinBuf = '';
        setTimeout(() => this.updatePinDisplay(), 200);
      }
    }
