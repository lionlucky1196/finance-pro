      </div>
      <button class="btn btn-primary btn-block" id="cat_add">+ Add Category</button>
      <h3 style="margin-top:16px">Income Categories</h3>
      <div id="cat_inc"></div>
      <h3 style="margin-top:12px">Expense Categories</h3>
      <div id="cat_exp"></div>
    `;
    openModal('Manage Categories', body, `<button class="btn btn-ghost" onclick="closeAllModals()">Close</button>`);
    const renderList = async () => {
      const cats = await db.getAll(STORES.categories);
      const inc = cats.filter(c => c.kind === 'income');
      const exp = cats.filter(c => c.kind === 'expense');
      const html = (arr) => arr.map(c =>
        `<div class="tx-item" style="margin-top:6px">
          <div class="tx-body"><div class="tx-title">${escapeHtml(c.name)}</div>
            <div class="tx-sub">${c.builtIn?'Built-in':'Custom'}</div></div>
          ${!c.builtIn ? `<button class="icon-btn" data-del="${c.id}"><span class="material-icons-round">delete</span></button>` : ''}
        </div>`).join('');
      document.getElementById('cat_inc').innerHTML = html(inc);
      document.getElementById('cat_exp').innerHTML = html(exp);
      document.querySelectorAll('[data-del]').forEach(b => b.onclick = async () => {
        await db.delete(STORES.categories, b.dataset.del); renderList();
      });
    };
    document.getElementById('cat_add').onclick = async () => {
      const name = document.getElementById('cat_name').value.trim();
      if (!name) { toast('Name required', 'error'); return; }
      await db.put(STORES.categories, {
        id: uid('c_'), name, kind: document.getElementById('cat_kind').value, builtIn: false
      });
      document.getElementById('cat_name').value = '';
      toast('Category added', 'success');
      renderList();
    };
    renderList();
  },

  openExportReportMenu() {
    const body = `
      <button class="btn btn-ghost btn-block" data-fmt="csv" style="margin-bottom:8px">📊 Export as CSV</button>
      <button class="btn btn-ghost btn-block" data-fmt="xlsx" style="margin-bottom:8px">📈 Export as Excel</button>
      <button class="btn btn-ghost btn-block" data-fmt="pdf" style="margin-bottom:8px">📄 Export as PDF</button>
      <button class="btn btn-ghost btn-block" data-fmt="json" style="margin-bottom:8px">🗂️ Export as JSON</button>
      <button class="btn btn-ghost btn-block" data-fmt="print">🖨️ Print Report</button>
    `;
    openModal('Export Report', body);
    document.querySelectorAll('[data-fmt]').forEach(b => {
      b.onclick = () => { Reports.exportCurrent(b.dataset.fmt); closeAllModals(); };
    });
  },

  async refreshAll() {
    await this.refreshDashboard();
    await this.renderTransactions();
    await Ledger.render(document.getElementById('ledgerSearch').value);
  }
};

/* ============ BOOT ============ */
window.addEventListener('load', () => App.init());
</script>
</body>
</html>
