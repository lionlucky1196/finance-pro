      }
    };
  },
  async renderOverview(canvasId) {
    const txs = await db.getAll(STORES.transactions);
    const c = this.colors();
    const months = [], incData = [], expData = [];
    const now = new Date();
    for (let i = 5; i >= 0; i--) {
