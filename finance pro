<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8" />
<meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no" />
<meta name="theme-color" content="#6366f1" />
<title>FinancePro — Premium Ledger & Finance Manager</title>
<link rel="icon" href="data:image/svg+xml,<svg xmlns=%22http://www.w3.org/2000/svg%22 viewBox=%220 0 100 100%22><text y=%22.9em%22 font-size=%2290%22>💰</text></svg>" />
<link href="https://fonts.googleapis.com/icon?family=Material+Icons+Round" rel="stylesheet" />
<link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&display=swap" rel="stylesheet" />
<script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.1/dist/chart.umd.min.js"></script>
<script src="https://cdnjs.cloudflare.com/ajax/libs/jspdf/2.5.1/jspdf.umd.min.js"></script>
<script src="https://cdnjs.cloudflare.com/ajax/libs/jspdf-autotable/3.8.2/jspdf.plugin.autotable.min.js"></script>
<script src="https://cdnjs.cloudflare.com/ajax/libs/xlsx/0.18.5/xlsx.full.min.js"></script>

<style>
/* ============ RESET & BASE ============ */
*,*::before,*::after{box-sizing:border-box;margin:0;padding:0}
html,body{height:100%;-webkit-tap-highlight-color:transparent}
body{
  font-family:'Inter',-apple-system,BlinkMacSystemFont,sans-serif;
  background:var(--bg);color:var(--text);
  font-size:15px;line-height:1.5;
  overflow-x:hidden;transition:background .3s,color .3s;
}
button{font-family:inherit;cursor:pointer;border:none;background:none;color:inherit}
input,select,textarea{font-family:inherit;font-size:15px;color:inherit}
h1,h2,h3{font-weight:700;letter-spacing:-.02em}
.muted{color:var(--text-muted)}

/* ============ THEME VARS ============ */
:root{
  --primary:#6366f1;--primary-dark:#4f46e5;--primary-soft:rgba(99,102,241,.12);
  --income:#10b981;--expense:#ef4444;--warn:#f59e0b;--info:#3b82f6;
  --bg:#f4f6fb;--surface:#ffffff;--surface-2:#f8fafc;
  --text:#0f172a;--text-muted:#64748b;--border:#e2e8f0;
  --shadow:0 4px 20px rgba(15,23,42,.06);
  --shadow-lg:0 20px 60px rgba(15,23,42,.15);
  --radius:16px;--radius-sm:10px;
}
[data-theme="dark"]{
  --bg:#0b1020;--surface:#131a2e;--surface-2:#1a2340;
  --text:#f1f5f9;--text-muted:#94a3b8;--border:#253056;
  --shadow:0 4px 20px rgba(0,0,0,.4);
  --shadow-lg:0 20px 60px rgba(0,0,0,.6);
}
[data-color="emerald"]{--primary:#10b981;--primary-dark:#059669;--primary-soft:rgba(16,185,129,.12)}
[data-color="rose"]{--primary:#f43f5e;--primary-dark:#e11d48;--primary-soft:rgba(244,63,94,.12)}
[data-color="amber"]{--primary:#f59e0b;--primary-dark:#d97706;--primary-soft:rgba(245,158,11,.12)}
[data-color="sky"]{--primary:#0ea5e9;--primary-dark:#0284c7;--primary-soft:rgba(14,165,233,.12)}
[data-color="violet"]{--primary:#8b5cf6;--primary-dark:#7c3aed;--primary-soft:rgba(139,92,246,.12)}

/* ============ SPLASH & LOCK ============ */
.splash{
  position:fixed;inset:0;background:linear-gradient(135deg,var(--primary),var(--primary-dark));
  display:flex;flex-direction:column;align-items:center;justify-content:center;
  color:#fff;z-index:9999;transition:opacity .5s;
}
.splash-logo{font-size:80px;animation:bounce 1s ease infinite alternate}
.splash h1{font-size:32px;margin-top:12px}
.splash p{opacity:.8;margin-top:4px}
.splash.hide{opacity:0;pointer-events:none}
@keyframes bounce{from{transform:translateY(0)}to{transform:translateY(-12px)}}

.lock-screen{
  position:fixed;inset:0;background:linear-gradient(135deg,var(--primary),var(--primary-dark));
  display:flex;align-items:center;justify-content:center;z-index:9998;padding:20px;
}
.lock-screen.hidden{display:none}
.lock-card{
  background:rgba(255,255,255,.12);backdrop-filter:blur(20px);-webkit-backdrop-filter:blur(20px);
  border:1px solid rgba(255,255,255,.2);border-radius:24px;padding:32px 24px;
  width:100%;max-width:360px;color:#fff;text-align:center;
}
.lock-logo{font-size:56px;margin-bottom:8px}
.lock-card h2{font-size:24px;margin-bottom:4px}
.lock-card p{opacity:.8;margin-bottom:20px;font-size:14px}
.pin-display{display:flex;justify-content:center;gap:14px;margin-bottom:28px}
.pin-display span{
  width:16px;height:16px;border-radius:50%;border:2px solid rgba(255,255,255,.5);
  transition:all .2s;
}
.pin-display span.filled{background:#fff;border-color:#fff;transform:scale(1.1)}
.pin-keypad{display:grid;grid-template-columns:repeat(3,1fr);gap:12px}
.pin-keypad button{
  height:60px;border-radius:16px;background:rgba(255,255,255,.12);color:#fff;
  font-size:22px;font-weight:600;transition:all .15s;
}
.pin-keypad button:active{transform:scale(.95);background:rgba(255,255,255,.25)}
.pin-keypad .key-sub{font-size:16px}
.btn-link{background:none;color:rgba(255,255,255,.9);margin-top:16px;padding:8px;font-size:14px;text-decoration:underline}
.btn-link.hidden{display:none}

/* ============ APP LAYOUT ============ */
.app.hidden{display:none}
.topbar{
  position:sticky;top:0;z-index:50;
  background:var(--surface);border-bottom:1px solid var(--border);
  padding:14px 18px;display:flex;align-items:center;justify-content:space-between;
  backdrop-filter:blur(10px);
}
.topbar-left{display:flex;align-items:center;gap:12px}
.logo-icon{font-size:32px}
.app-title{font-weight:700;font-size:17px}
.app-sub{font-size:12px;color:var(--text-muted)}
.topbar-right{display:flex;gap:6px}
.icon-btn{
  width:40px;height:40px;border-radius:12px;display:flex;align-items:center;justify-content:center;
  transition:background .2s;color:var(--text);
}
.icon-btn:hover,.icon-btn:active{background:var(--primary-soft)}

.search-bar{
  position:sticky;top:68px;z-index:49;background:var(--surface);
  padding:10px 18px;display:flex;align-items:center;gap:10px;border-bottom:1px solid var(--border);
}
.search-bar.hidden{display:none}
.search-bar input{
  flex:1;background:var(--surface-2);border:1px solid var(--border);border-radius:10px;
  padding:10px 12px;outline:none;color:var(--text);
}
.search-bar input:focus{border-color:var(--primary)}

.main{padding:16px 16px 120px;max-width:1200px;margin:0 auto}
.page{display:none;animation:fadeIn .3s}
.page.active{display:block}
@keyframes fadeIn{from{opacity:0;transform:translateY(8px)}to{opacity:1;transform:translateY(0)}}

/* ============ DASHBOARD ============ */
.greeting{margin-bottom:18px}
.greeting h1{font-size:26px}
.greeting p{color:var(--text-muted);font-size:14px;margin-top:2px}

.stat-grid{
  display:grid;grid-template-columns:repeat(2,1fr);gap:12px;margin-bottom:20px;
}
@media(min-width:768px){.stat-grid{grid-template-columns:repeat(4,1fr)}}
.stat-card{
  background:var(--surface);border-radius:var(--radius);padding:16px;
  box-shadow:var(--shadow);position:relative;overflow:hidden;
  border:1px solid var(--border);transition:transform .2s;
}
.stat-card:hover{transform:translateY(-2px)}
.stat-card::before{
  content:'';position:absolute;top:0;left:0;right:0;height:3px;
  background:var(--primary);
}
.stat-balance::before{background:linear-gradient(90deg,var(--primary),var(--info))}
.stat-income::before{background:var(--income)}
.stat-expense::before{background:var(--expense)}
.stat-today::before{background:var(--warn)}
.stat-month-in::before{background:var(--income)}
.stat-month-out::before{background:var(--expense)}
.stat-profit::before{background:linear-gradient(90deg,var(--income),var(--primary))}
.stat-loan::before{background:var(--warn)}
.stat-icon{
  width:40px;height:40px;border-radius:12px;background:var(--primary-soft);
  display:flex;align-items:center;justify-content:center;color:var(--primary);
  margin-bottom:10px;
}
.stat-income .stat-icon{background:rgba(16,185,129,.12);color:var(--income)}
.stat-expense .stat-icon{background:rgba(239,68,68,.12);color:var(--expense)}
.stat-today .stat-icon{background:rgba(245,158,11,.12);color:var(--warn)}
.stat-month-in .stat-icon{background:rgba(16,185,129,.12);color:var(--income)}
.stat-month-out .stat-icon{background:rgba(239,68,68,.12);color:var(--expense)}
.stat-loan .stat-icon{background:rgba(245,158,11,.12);color:var(--warn)}
.stat-label{font-size:12px;color:var(--text-muted);font-weight:500}
.stat-value{font-size:20px;font-weight:700;margin-top:4px;word-break:break-all}
.stat-sub{font-size:11px;color:var(--text-muted);margin-top:2px}

.quick-actions{margin-bottom:20px}
.quick-actions h3{margin-bottom:10px;font-size:16px}
.qa-grid{display:grid;grid-template-columns:repeat(4,1fr);gap:10px}
.qa-btn{
  background:var(--surface);border:1px solid var(--border);border-radius:14px;
  padding:14px 8px;display:flex;flex-direction:column;align-items:center;gap:4px;
  font-size:12px;font-weight:500;transition:all .2s;
}
.qa-btn:hover{transform:translateY(-2px);box-shadow:var(--shadow)}
.qa-btn .material-icons-round{font-size:22px}
.qa-btn.income{color:var(--income)}
.qa-btn.expense{color:var(--expense)}
.qa-btn.transfer{color:var(--info)}
.qa-btn.loan{color:var(--warn)}

.card{
  background:var(--surface);border-radius:var(--radius);padding:16px;
  box-shadow:var(--shadow);border:1px solid var(--border);margin-bottom:16px;
}
.card h3{font-size:16px;margin-bottom:12px}
.card-head{display:flex;justify-content:space-between;align-items:center;margin-bottom:12px}
.card-head h3{margin:0}
.two-col{display:grid;grid-template-columns:1fr;gap:16px}
@media(min-width:768px){.two-col{grid-template-columns:1fr 1fr}}
.chart-wrap{position:relative;height:240px}

/* ============ BUTTONS ============ */
.btn{
  padding:10px 16px;border-radius:10px;font-weight:600;font-size:14px;
  display:inline-flex;align-items:center;gap:6px;transition:all .2s;
}
.btn-primary{background:var(--primary);color:#fff}
.btn-primary:hover{background:var(--primary-dark)}
.btn-ghost{background:var(--surface-2);color:var(--text);border:1px solid var(--border)}
.btn-ghost:hover{background:var(--primary-soft)}
.btn-danger{background:var(--expense);color:#fff}
.btn-danger:hover{filter:brightness(.9)}
.btn-block{width:100%;justify-content:center}
.btn-link-dark{color:var(--primary);padding:4px 8px;font-size:13px;font-weight:500}

/* ============ PAGE HEAD ============ */
.page-head{display:flex;justify-content:space-between;align-items:center;margin-bottom:16px;flex-wrap:wrap;gap:10px}
.page-head h2{font-size:22px}
.page-actions{display:flex;gap:8px}

/* ============ TX LIST ============ */
.tx-list{display:flex;flex-direction:column;gap:8px}
.tx-list.full{min-height:300px}
.tx-item{
  background:var(--surface);border:1px solid var(--border);border-radius:14px;
  padding:12px 14px;display:flex;align-items:center;gap:12px;
  transition:all .2s;position:relative;
}
.tx-item:hover{transform:translateX(2px);box-shadow:var(--shadow)}
.tx-icon{
  width:42px;height:42px;border-radius:12px;display:flex;align-items:center;justify-content:center;
  flex-shrink:0;font-size:20px;
}
.tx-icon.income{background:rgba(16,185,129,.12);color:var(--income)}
.tx-icon.expense{background:rgba(239,68,68,.12);color:var(--expense)}
.tx-icon.transfer{background:rgba(59,130,246,.12);color:var(--info)}
.tx-icon.loan{background:rgba(245,158,11,.12);color:var(--warn)}
.tx-body{flex:1;min-width:0}
.tx-title{font-weight:600;font-size:14px;white-space:nowrap;overflow:hidden;text-overflow:ellipsis}
.tx-sub{font-size:12px;color:var(--text-muted);margin-top:2px;display:flex;gap:8px;flex-wrap:wrap}
.tx-amount{font-weight:700;font-size:15px;text-align:right;white-space:nowrap}
.tx-amount.income{color:var(--income)}
.tx-amount.expense{color:var(--expense)}
.tx-amount.transfer{color:var(--info)}
.tx-amount.loan{color:var(--warn)}
.tx-menu-btn{padding:4px;color:var(--text-muted)}

.empty-state{
  text-align:center;padding:60px 20px;color:var(--text-muted);
}
.empty-state .material-icons-round{font-size:64px;opacity:.3;margin-bottom:12px}
.empty-state h3{color:var(--text);margin-bottom:4px}
.empty-state.hidden{display:none}

/* ============ FILTERS ============ */
.filter-panel{
  background:var(--surface);border:1px solid var(--border);border-radius:var(--radius);
  padding:16px;margin-bottom:16px;
}
.filter-panel.hidden{display:none}
.filter-grid{display:grid;grid-template-columns:repeat(2,1fr);gap:10px}
@media(min-width:768px){.filter-grid{grid-template-columns:repeat(4,1fr)}}
.filter-grid label{font-size:12px;color:var(--text-muted);margin-bottom:4px;display:block}
.filter-grid input,.filter-grid select{
  width:100%;padding:8px 10px;border:1px solid var(--border);border-radius:8px;
  background:var(--surface-2);outline:none;color:var(--text);
}
.filter-grid input:focus,.filter-grid select:focus{border-color:var(--primary)}
.filter-actions{display:flex;gap:8px;margin-top:12px;justify-content:flex-end}

/* ============ PERSON LIST ============ */
.ledger-search{
  background:var(--surface);border:1px solid var(--border);border-radius:12px;
  padding:10px 14px;display:flex;align-items:center;gap:10px;margin-bottom:14px;
}
.ledger-search input{flex:1;border:none;background:none;outline:none;color:var(--text)}
.person-list{display:grid;grid-template-columns:1fr;gap:10px}
@media(min-width:768px){.person-list{grid-template-columns:repeat(2,1fr)}}
.person-card{
  background:var(--surface);border:1px solid var(--border);border-radius:14px;
  padding:14px;cursor:pointer;transition:all .2s;
}
.person-card:hover{transform:translateY(-2px);box-shadow:var(--shadow)}
.person-head{display:flex;align-items:center;gap:10px;margin-bottom:10px}
.person-avatar{
  width:42px;height:42px;border-radius:50%;background:var(--primary-soft);
  color:var(--primary);display:flex;align-items:center;justify-content:center;
  font-weight:700;font-size:16px;
}
.person-name{font-weight:600;font-size:15px}
.person-phone{font-size:12px;color:var(--text-muted)}
.person-stats{display:grid;grid-template-columns:repeat(3,1fr);gap:6px;margin-top:8px}
.person-stat{text-align:center;padding:6px;background:var(--surface-2);border-radius:8px}
.person-stat .label{font-size:10px;color:var(--text-muted);text-transform:uppercase}
.person-stat .value{font-size:13px;font-weight:700;margin-top:2px}
.person-stat.given .value{color:var(--expense)}
.person-stat.received .value{color:var(--income)}
.person-stat.balance .value{color:var(--primary)}
.fav-star{color:var(--warn);font-size:18px}

/* ============ REPORTS ============ */
.report-tabs{
  display:flex;gap:6px;overflow-x:auto;margin-bottom:16px;padding-bottom:4px;
  scrollbar-width:none;
}
.report-tabs::-webkit-scrollbar{display:none}
.tab{
  padding:8px 16px;border-radius:20px;background:var(--surface);border:1px solid var(--border);
  font-size:13px;font-weight:500;white-space:nowrap;transition:all .2s;
}
.tab.active{background:var(--primary);color:#fff;border-color:var(--primary)}
.report-summary{
  display:grid;grid-template-columns:repeat(3,1fr);gap:10px;margin-bottom:16px;
}
.summary-box{
  background:var(--surface);border:1px solid var(--border);border-radius:12px;
  padding:12px;text-align:center;
}
.summary-box .label{font-size:11px;color:var(--text-muted);text-transform:uppercase}
.summary-box .value{font-size:18px;font-weight:700;margin-top:4px}
.report-table{
  width:100%;border-collapse:collapse;background:var(--surface);border-radius:12px;overflow:hidden;
}
.report-table th,.report-table td{
  padding:10px 12px;text-align:left;border-bottom:1px solid var(--border);font-size:13px;
}
.report-table th{background:var(--surface-2);font-weight:600;font-size:12px;color:var(--text-muted);text-transform:uppercase}
.report-table tr:last-child td{border-bottom:none}

/* ============ TOOLS ============ */
.tool-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:10px}
@media(min-width:768px){.tool-grid{grid-template-columns:repeat(6,1fr)}}
.tool-btn{
  background:var(--surface-2);border:1px solid var(--border);border-radius:12px;
  padding:14px 8px;display:flex;flex-direction:column;align-items:center;gap:6px;
  font-size:11px;font-weight:500;transition:all .2s;color:var(--text);
}
.tool-btn:hover{background:var(--primary-soft);border-color:var(--primary)}
.tool-btn .material-icons-round{font-size:24px;color:var(--primary)}

/* ============ SETTINGS ============ */
.setting-row{
  display:flex;justify-content:space-between;align-items:center;padding:12px 0;
  border-bottom:1px solid var(--border);
}
.setting-row:last-child{border-bottom:none}
.setting-row select,.setting-row input{
  padding:8px 10px;border:1px solid var(--border);border-radius:8px;
  background:var(--surface-2);outline:none;
}

/* ============ BOTTOM NAV ============ */
.bottom-nav{
  position:fixed;bottom:14px;left:14px;right:14px;max-width:480px;margin:0 auto;
  background:var(--surface);border:1px solid var(--border);border-radius:20px;
  padding:8px;display:flex;justify-content:space-around;box-shadow:var(--shadow-lg);
  z-index:40;
}
.nav-btn{
  flex:1;padding:10px 4px;border-radius:14px;display:flex;flex-direction:column;align-items:center;gap:2px;
  color:var(--text-muted);font-size:10px;font-weight:500;transition:all .2s;
}
.nav-btn.active{background:var(--primary-soft);color:var(--primary)}
.nav-btn .material-icons-round{font-size:22px}

.fab{
  position:fixed;bottom:92px;right:20px;width:58px;height:58px;border-radius:50%;
  background:var(--primary);color:#fff;display:flex;align-items:center;justify-content:center;
  box-shadow:0 8px 24px rgba(99,102,241,.5);z-index:41;transition:all .2s;
}
.fab:hover{transform:scale(1.08) rotate(90deg)}
.fab .material-icons-round{font-size:28px}

/* ============ MODAL ============ */
.modal{
  position:fixed;inset:0;background:rgba(0,0,0,.5);backdrop-filter:blur(6px);
  display:flex;align-items:flex-end;justify-content:center;z-index:100;
  animation:fadeIn .2s;
}
@media(min-width:768px){.modal{align-items:center}}
.modal-content{
  background:var(--surface);border-radius:20px 20px 0 0;width:100%;max-width:600px;
  max-height:92vh;overflow-y:auto;animation:slideUp .3s;
}
@media(min-width:768px){.modal-content{border-radius:20px;max-height:85vh}}
@keyframes slideUp{from{transform:translateY(40px);opacity:0}to{transform:translateY(0);opacity:1}}
.modal-head{
  position:sticky;top:0;background:var(--surface);padding:16px 20px;
  display:flex;justify-content:space-between;align-items:center;border-bottom:1px solid var(--border);
  z-index:2;
}
.modal-head h3{font-size:18px}
.modal-body{padding:20px}
.modal-foot{padding:12px 20px;border-top:1px solid var(--border);display:flex;gap:10px;justify-content:flex-end}
.modal-foot .btn{flex:1}

.form-group{margin-bottom:14px}
.form-group label{font-size:12px;font-weight:500;color:var(--text-muted);margin-bottom:6px;display:block}
.form-group input,.form-group select,.form-group textarea{
  width:100%;padding:11px 13px;border:1px solid var(--border);border-radius:10px;
  background:var(--surface-2);outline:none;color:var(--text);transition:border .2s;
}
.form-group input:focus,.form-group select:focus,.form-group textarea:focus{border-color:var(--primary)}
.form-group textarea{resize:vertical;min-height:70px}
.form-row{display:grid;grid-template-columns:1fr 1fr;gap:10px}
.form-row-3{display:grid;grid-template-columns:1fr 1fr 1fr;gap:10px}

.type-tabs{display:flex;gap:6px;margin-bottom:14px;flex-wrap:wrap}
.type-tab{
  padding:8px 12px;border-radius:10px;background:var(--surface-2);border:1px solid var(--border);
  font-size:12px;font-weight:500;transition:all .2s;
}
.type-tab.active{background:var(--primary);color:#fff;border-color:var(--primary)}

.tag-chip{
  display:inline-flex;align-items:center;gap:4px;padding:4px 10px;border-radius:16px;
  background:var(--primary-soft);color:var(--primary);font-size:12px;margin:2px 4px 2px 0;
}
.tag-chip button{font-size:14px;color:var(--primary)}

/* ============ TOAST ============ */
.toast-root{
  position:fixed;bottom:120px;left:50%;transform:translateX(-50%);
  z-index:200;display:flex;flex-direction:column;gap:8px;pointer-events:none;
}
.toast{
  background:var(--text);color:var(--surface);padding:12px 20px;border-radius:12px;
  font-size:14px;box-shadow:var(--shadow-lg);animation:toastIn .3s;
  display:flex;align-items:center;gap:10px;max-width:340px;
}
.toast.success{background:var(--income)}
.toast.error{background:var(--expense)}
.toast.info{background:var(--info)}
.toast button{background:rgba(255,255,255,.2);padding:4px 10px;border-radius:6px;font-size:12px;color:#fff}
